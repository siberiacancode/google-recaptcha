{
  "name": "@google-recaptcha/docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev --turbo",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint . --fix",
    "lint-inspector": "npx @eslint/config-inspector@latest",
    "format": "prettier --write .",
