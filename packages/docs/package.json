    "pretty": "yarn type && yarn lint && yarn format",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@google-recaptcha/core": "^1.1.2",
    "@google-recaptcha/react": "^2.4.0",
    "@google-recaptcha/vue": "^1.3.2",
    "@orama/orama": "^3.1.18",
    "@radix-ui/react-slot": "^1.2.4",
    "@siberiacancode/reactuse": "0.3.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fumadocs-core": "16.4.9",
    "fumadocs-docgen": "^3.0.5",
    "fumadocs-mdx": "14.2.6",
    "fumadocs-twoslash": "^3.1.12",
    "fumadocs-ui": "16.4.9",
    "lucide-react": "^0.563.0",
    "next": "16.1.5",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.4.0",
    "twoslash": "^0.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/mdx": "^2.0.13",
    "@types/node": "25.0.10",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,ts,md,mdx,tsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
